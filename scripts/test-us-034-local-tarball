#!/bin/sh

# Integration test for local-tarball source registration and apply flow (US-034)
# Tests that both archive structures (root-level manifest and single-top-level-dir)
# work identically

set -eu

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)
HELPER="$SCRIPT_DIR/opencode-helper"
REPO_ROOT=$(CDPATH= cd "$SCRIPT_DIR/.." && pwd)

fail() {
  printf 'FAIL: %s\n' "$1" >&2
  exit 1
}

assert_text_contains() {
  text=$1
  expected=$2
  case "$text" in
    *"$expected"*) ;;
    *) fail "expected '$expected' in text output" ;;
  esac
}

assert_text_not_contains() {
  text=$1
  expected=$2
  case "$text" in
    *"$expected"*) fail "did not expect '$expected' in text output" ;;
    *) ;;
  esac
}

assert_text_contains_any() {
  text=$1
  shift
  for expected in "$@"; do
    case "$text" in
      *"$expected"*) return 0 ;;
    esac
  done
  fail "expected one of '$*' in text output"
}

# Create a minimal test bundle manifest
create_manifest() {
  dest_dir=$1
  cat > "$dest_dir/opencode-bundle.manifest.json" <<'EOF'
{
  "manifest_version": 1,
  "bundle_name": "test-bundle",
  "bundle_version": "1.0.0",
  "presets": [
    {
      "name": "test-preset",
      "description": "Test preset for integration testing",
      "entrypoint": "test-preset.json",
      "prompt_files": ["prompts/test.txt"]
    }
  ]
}
EOF
  mkdir -p "$dest_dir/prompts"
  echo "Test prompt content" > "$dest_dir/prompts/test.txt"
  echo '{"agents": []}' > "$dest_dir/test-preset.json"
}

# Test 1: Archive with single top-level directory
test_single_top_level_dir() {
  printf '=== Test: Single top-level directory ===\n'
  
  tmp_archive=$(mktemp "${TMPDIR:-/tmp}/test-bundle-single.XXXXXX.tar.gz" 2>/dev/null) || tmp_archive=$(mktemp "/tmp/test-bundle-single-$$-$(date +%s).tar.gz")
  tmp_bundle=$(mktemp -d "${TMPDIR:-/tmp}/test-bundle-single-content.XXXXXX" 2>/dev/null) || tmp_bundle=$(mktemp -d "/tmp/test-bundle-single-content-$$-$(date +%s)")
  
  # Create bundle content under a single top-level directory
  mkdir -p "$tmp_bundle/bundle"
  create_manifest "$tmp_bundle/bundle"
  tar -czf "$tmp_archive" -C "$tmp_bundle" bundle
  
  # Test source add
  output=$(sh "$HELPER" source add "$tmp_archive" 2>&1) || fail "source add failed: $output"
  assert_text_contains "$output" "local-tarball"
  assert_text_not_contains "$output" "error"
  
  # Extract source ID from output (format: "added source: name (ID: 123, type: local-tarball)")
  source_id=$(printf '%s\n' "$output" | grep 'ID:' | sed 's/.*ID: *\([0-9]*\).*/\1/')
  [ -n "$source_id" ] || fail "could not extract source ID"
  
  printf 'Registered source ID: %s\n' "$source_id"
  
  # Test bundle apply
  tmp_project=$(mktemp -d "${TMPDIR:-/tmp}/test-project.XXXXXX")
  apply_output=$(sh "$HELPER" bundle apply "$source_id" --preset test-preset --project-root "$tmp_project" 2>&1) || {
    rm -rf "$tmp_archive" "$tmp_bundle" "$tmp_project"
    fail "bundle apply failed: $apply_output"
  }
  
  # Verify apply was successful
  assert_text_contains_any "$apply_output" "ok:" "applied"
  
  printf 'Single top-level directory test: PASS\n'
  
  rm -rf "$tmp_archive" "$tmp_bundle" "$tmp_project"
}

# Test 2: Archive with manifest at root level
test_manifest_at_root() {
  printf '=== Test: Manifest at root level ===\n'
  
  tmp_archive=$(mktemp "${TMPDIR:-/tmp}/test-bundle-root.XXXXXX.tar.gz" 2>/dev/null) || tmp_archive=$(mktemp "/tmp/test-bundle-root-$$-$(date +%s).tar.gz")
  tmp_bundle=$(mktemp -d "${TMPDIR:-/tmp}/test-bundle-root-content.XXXXXX" 2>/dev/null) || tmp_bundle=$(mktemp -d "/tmp/test-bundle-root-content-$$-$(date +%s)")
  
  # Create bundle content directly at root (no wrapper directory)
  create_manifest "$tmp_bundle"
  tar -czf "$tmp_archive" -C "$tmp_bundle" .
  
  # Test source add
  output=$(sh "$HELPER" source add "$tmp_archive" 2>&1) || fail "source add failed: $output"
  assert_text_contains "$output" "local-tarball"
  assert_text_not_contains "$output" "error"
  
  # Extract source ID from output (format: "added source: name (ID: 123, type: local-tarball)")
  source_id=$(printf '%s\n' "$output" | grep 'ID:' | sed 's/.*ID: *\([0-9]*\).*/\1/')
  [ -n "$source_id" ] || fail "could not extract source ID"
  
  printf 'Registered source ID: %s\n' "$source_id"
  
  # Test bundle apply
  tmp_project=$(mktemp -d "${TMPDIR:-/tmp}/test-project.XXXXXX")
  apply_output=$(sh "$HELPER" bundle apply "$source_id" --preset test-preset --project-root "$tmp_project" 2>&1) || {
    rm -rf "$tmp_archive" "$tmp_bundle" "$tmp_project"
    fail "bundle apply failed: $apply_output"
  }
  
  # Verify apply was successful
  assert_text_contains_any "$apply_output" "ok:" "applied"
  
  printf 'Manifest at root test: PASS\n'
  
  rm -rf "$tmp_archive" "$tmp_bundle" "$tmp_project"
}

# Test 3: Archive with multiple top-level items should fail
test_multiple_top_level_should_fail() {
  printf '=== Test: Multiple top-level items should fail ===\n'
  
  tmp_archive=$(mktemp "${TMPDIR:-/tmp}/test-bundle-multi.XXXXXX.tar.gz")
  tmp_bundle=$(mktemp -d "${TMPDIR:-/tmp}/test-bundle-multi-content.XXXXXX")
  
  # Create bundle with multiple top-level items (no manifest)
  mkdir -p "$tmp_bundle/dir1"
  mkdir -p "$tmp_bundle/dir2"
  echo "file1" > "$tmp_bundle/file1.txt"
  tar -czf "$tmp_archive" -C "$tmp_bundle" .
  
  # Test source add should fail
  output=$(sh "$HELPER" source add "$tmp_archive" 2>&1) || true
  assert_text_contains "$output" "multiple top-level items"
  
  printf 'Multiple top-level items test: PASS (correctly rejected)\n'
  
  rm -rf "$tmp_archive" "$tmp_bundle"
}

# Test 4: Empty archive should fail
test_empty_archive_should_fail() {
  printf '=== Test: Empty archive should fail ===\n'
  
  tmp_archive=$(mktemp "${TMPDIR:-/tmp}/test-bundle-empty.XXXXXX.tar.gz" 2>/dev/null) || tmp_archive=$(mktemp "/tmp/test-bundle-empty-$$-$(date +%s).tar.gz")
  
  # Create empty archive
  tar -czf "$tmp_archive" -T /dev/null
  
  # Test source add should fail
  output=$(sh "$HELPER" source add "$tmp_archive" 2>&1) || true
  assert_text_contains "$output" "tarball is empty"
  
  printf 'Empty archive test: PASS (correctly rejected)\n'
  
  rm -rf "$tmp_archive"
}

# Test 5: Archive with files at root but no manifest should fail
test_no_manifest_should_fail() {
  printf '=== Test: No manifest should fail ===\n'
  
  tmp_archive=$(mktemp "${TMPDIR:-/tmp}/test-bundle-noman.XXXXXX.tar.gz" 2>/dev/null) || tmp_archive=$(mktemp "/tmp/test-bundle-noman-$$-$(date +%s).tar.gz")
  tmp_bundle=$(mktemp -d "${TMPDIR:-/tmp}/test-bundle-noman-content.XXXXXX" 2>/dev/null) || tmp_bundle=$(mktemp -d "/tmp/test-bundle-noman-content-$$-$(date +%s)")
  
  # Create bundle without manifest at root
  echo "some content" > "$tmp_bundle/somefile.txt"
  tar -czf "$tmp_archive" -C "$tmp_bundle" .
  
  # Test source add should fail
  output=$(sh "$HELPER" source add "$tmp_archive" 2>&1) || true
  assert_text_contains "$output" "missing bundle manifest"
  
  printf 'No manifest test: PASS (correctly rejected)\n'
  
  rm -rf "$tmp_archive" "$tmp_bundle"
}

# Run all tests
test_single_top_level_dir
test_manifest_at_root
test_multiple_top_level_should_fail
test_empty_archive_should_fail
test_no_manifest_should_fail

printf '\n=== All US-034 integration tests PASSED ===\n'
